{
  "name": "@dorsk/uikit",
  "version": "0.1.0",
  "description": "Minimal, dependency-free Svelte 5 + pure-CSS UI kit. Token-driven atoms & molecules with theming out of the box.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "exports": {
    ".": "./src/lib/index.ts",
    "./styles/app.css": "./src/lib/styles/app.css",
    "./styles/variables.css": "./src/lib/styles/variables.css"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^25.9.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
