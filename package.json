{
  "name": "@dorsk/tsumikit",
  "version": "0.18.1",
  "description": "Minimal, dependency-free Svelte 5 + pure-CSS UI kit. Token-driven atoms, molecules & layouts with theming out of the box.",
  "type": "module",
  "license": "MIT",
  "author": "Dorsk <dorsk.dev@gmail.com>",
  "homepage": "https://dorskfr.github.io/tsumikit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DorskFR/tsumikit.git"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "ui",
    "components",
    "design-system",
    "css",
    "theming",
    "accessibility"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/app.css": "./dist/styles/app.css",
    "./styles/variables.css": "./dist/styles/variables.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test tests/*.test.js",
    "prepare": "svelte-kit sync && (lefthook install || true)",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "format": "biome check --write .",
    "package": "svelte-kit sync && svelte-package && publint",
    "package:watch": "svelte-kit sync && svelte-package --watch",
    "prepublishOnly": "npm run package"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^25.9.3",
    "lefthook": "^1.7.0",
    "publint": "^0.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
